# ─── AI Service .env.example ──────────────────────────────────────────────────
# Copy this file to the root .env (shared with backend) and fill in real values.
# Never commit .env to git.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres

# ── LLM API Keys ──────────────────────────────────────────
MISTRAL_API_KEY=<YOUR_MISTRAL_KEY>
GROQ_API_KEY=<YOUR_GROQ_KEY>
OPENAI_API_KEY=<YOUR_OPENAI_KEY>   # optional fallback

# ── Twilio ────────────────────────────────────────────────
TWILIO_SSID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_NUMBER=+14155238886

# Sandbox redirect — dev only. Leave empty in production.
SANDBOX_REDIRECT_NUMBERS=

# ── Backend URL ───────────────────────────────────────────
# URL of the Node backend. Change to deployed URL in production.
BACKEND_URL=http://localhost:5000

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production: set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── JWT Secret (must match backend) ──────────────────────
# Used to sign service-to-service tokens between AI service and backend.
# Generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_STRONG_RANDOM_SECRET>

# ── Cloudinary, Google, Supabase (if needed) ─────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET_KEY=
GOOGLE_OAUTH_KEY=
GOOGLE_CLIENT_SECRET=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
