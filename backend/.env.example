# ─── Backend .env.example ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────
# Supabase PostgreSQL connection string (Transaction/Session mode)
DATABASE_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT>.supabase.co:5432/postgres

# ── Authentication ────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<CHANGE_ME_STRONG_RANDOM_SECRET>
JWT_REFRESH_SECRET=<CHANGE_ME_STRONG_RANDOM_SECRET>

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Dev default (set automatically if omitted): http://localhost:3000
# Production: set to your deployed frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Twilio WhatsApp ───────────────────────────────────────
TWILIO_SSID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_NUMBER=+14155238886

# Sandbox redirect — dev only. Leave empty or omit in production.
# When set, ALL outbound messages are redirected to these numbers.
SANDBOX_REDIRECT_NUMBERS=

# ── Cloudinary (media uploads) ────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET_KEY=

# ── Google OAuth ──────────────────────────────────────────
GOOGLE_OAUTH_KEY=
GOOGLE_CLIENT_SECRET=

# ── AI Service ────────────────────────────────────────────
# URL of the Python AI service. Change to deployed URL in production.
AI_SERVICE_URL=http://localhost:8000

# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
